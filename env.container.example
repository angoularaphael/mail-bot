# Boxing Center — Mail Bot
# Bot-hosting : copier ce fichier vers /home/container/.env
# Ne jamais committer le .env avec les vraies clés.
#
# ─── Port (obligatoire sur bot-hosting) ───────────────────────────────────────
SERVER_PORT=20XXX          # Port attribué par bot-hosting (voir votre tableau de bord)
PORT=20XXX

# ─── IMAP Gmail ───────────────────────────────────────────────────────────────
# Prérequis :
#   1. Ouvrir Gmail → Paramètres → Transfert et POP/IMAP → Activer IMAP
#   2. Compte Google → Sécurité → Mots de passe des applications → générer (16 car.)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_TLS=true
IMAP_USER=angoularaphael05@gmail.com
IMAP_PASS=                         # ← mot de passe d'application Gmail (16 car.)

# ─── Brevo — API REST (prioritaire) ou SMTP ──────────────────────────────────
BREVO_API_KEY=                             # ← clé API Brevo (xkeysib-…)
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_LOGIN=ae591b001@smtp-brevo.com
BREVO_SMTP_KEY=                             # ← clé SMTP Brevo (xsmtpsib-...)
BREVO_SENDER_EMAIL=suzinabot@gmail.com
BREVO_SENDER_NAME=Boxing Center
BREVO_REPLY_TO=boxingcenter31@gmail.com

# ─── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://ulxtbvxdueolvnjhpzvw.supabase.co
SUPABASE_SERVICE_ROLE_KEY=                 # ← clé service role Supabase (eyJ...)

# ─── Routing responsables ─────────────────────────────────────────────────────
MAIL_RECEPTION=boxingcenter31@gmail.com
MAIL_MANAGER=boxingcenter31@gmail.com
MAIL_COMPTA=boxingcenter31@gmail.com
MAIL_DIRECTION=boxingcenter31@gmail.com
MAIL_COACH=boxingcenter31@gmail.com

# ─── Comportement ─────────────────────────────────────────────────────────────
POLL_INTERVAL_MS=300000     # Vérification toutes les 5 minutes
MAX_EMAILS_PER_RUN=50
BOT_DRY_RUN=false

# ─── Identité ─────────────────────────────────────────────────────────────────
BOXING_CENTER_SITE_URL=https://boxingcenter.fr/
BOXING_CENTER_CONTACT_EMAIL=boxingcenter31@gmail.com
