# ── IMAP — lecture des emails entrants ─────────────────────────────────────
# Pour Gmail : Paramètres → Transfert et POP/IMAP → Activer IMAP
# Puis : Compte Google → Sécurité → Mots de passe des applications (si 2FA activée)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_TLS=true
IMAP_USER=angoularaphael05@gmail.com
IMAP_PASS=                         # Mot de passe d'application Google (16 car.)

# ── Brevo — API REST (prioritaire) ou SMTP ───────────────────
# BREVO_API_KEY évite l'erreur "525 Unauthorized IP" sur bot-hosting
BREVO_API_KEY=                         # clé xkeysib-… depuis Brevo
# Mêmes valeurs que dans BOXPLUS/.env
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_LOGIN=ae591b001@smtp-brevo.com
BREVO_SMTP_KEY=
BREVO_SENDER_EMAIL=suzinabot@gmail.com
BREVO_SENDER_NAME=Boxing Center
BREVO_REPLY_TO=boxingcenter31@gmail.com

# ── Supabase — historique & suivi ──────────────────────────────────────────
SUPABASE_URL=https://ulxtbvxdueolvnjhpzvw.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ── Routing — adresse de chaque responsable ────────────────────────────────
# La même adresse peut être utilisée pour plusieurs rôles
MAIL_RECEPTION=boxingcenter31@gmail.com    # Inscription, séance essai, autre
MAIL_MANAGER=boxingcenter31@gmail.com      # Résiliation, réclamation
MAIL_COMPTA=boxingcenter31@gmail.com       # Remboursement, facture
MAIL_DIRECTION=boxingcenter31@gmail.com    # Partenariat
MAIL_COACH=boxingcenter31@gmail.com        # Compétition, enfant/ado

# ── Comportement du bot ────────────────────────────────────────────────────
POLL_INTERVAL_MS=300000      # Intervalle de vérification en mode --watch (ms) — 5 min
MAX_EMAILS_PER_RUN=50        # Nombre max d'emails traités par cycle
MIN_CONFIDENCE=3           # score min pour traiter un email (ignore le bruit)
BOT_DRY_RUN=false            # true = classification uniquement, sans envoyer ni transmettre

# ── Alertes webhook (optionnel) ────────────────────────────────────────────
ALERT_WEBHOOK_URL=           # URL à appeler pour les emails urgents
BOXING_CENTER_SITE_URL=https://boxingcenter.fr/
BOXING_CENTER_CONTACT_EMAIL=boxingcenter31@gmail.com
